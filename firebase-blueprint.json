{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user preferences and data.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of game IDs the user has favorited."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was last updated."
        }
      },
      "required": ["uid", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profiles."
    }
  }
}
